<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_12"
    android:paddingHorizontal="@dimen/spacing_8"
    android:gravity="center_vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_profile_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="@string/participant_avatar" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_participant_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/participant_name"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_attended"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                android:tint="@color/success_color"
                android:contentDescription="@string/attended"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_4">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_calendar"
                android:tint="?android:attr/textColorSecondary"
                android:contentDescription="@string/registered_date" />

            <TextView
                android:id="@+id/tv_registered_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terdaftar 10 hari lalu"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginStart="@dimen/spacing_6" />

        </LinearLayout>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_participant_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_more_vert"
        android:scaleType="centerInside"
        android:background="@drawable/ripple_background"
        android:tint="?android:attr/textColorSecondary"
        android:contentDescription="@string/more_options"
        android:layout_marginStart="@dimen/spacing_8" />

</LinearLayout>
