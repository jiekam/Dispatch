<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingVertical="@dimen/spacing_8"
    android:paddingHorizontal="@dimen/spacing_4">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iv_info_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_calendar"
        android:tint="@color/primary_red"
        android:scaleType="centerInside"
        android:contentDescription="@string/info_icon" />

    <!-- Label -->
    <TextView
        android:id="@+id/tv_info_label"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:text="@string/date"
        android:textSize="12sp"
        android:textColor="@color/text_gray"
        android:layout_marginStart="@dimen/spacing_12" />

    <!-- Value -->
    <TextView
        android:id="@+id/tv_info_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Sabtu, 14 Maret"
        android:textSize="13sp"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:layout_marginStart="@dimen/spacing_8" />

</LinearLayout>
