<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_clock"
        android:tint="@color/primary_red"
        android:scaleType="centerInside"
        android:contentDescription="Menunggu" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Akun Sedang Ditinjau"
        android:textSize="22sp"
        android:textColor="@color/text_dark"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Akun organizer Anda sedang dalam proses review oleh admin.\n\nAnda akan dapat mengakses aplikasi setelah akun disetujui.\n\nProses ini biasanya memakan waktu 1–2 hari kerja."
        android:textSize="14sp"
        android:textColor="@color/text_gray"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btn_check_status"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cek Status"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:backgroundTint="@color/primary_red"
        android:layout_marginTop="40dp"
        style="@style/Widget.MaterialComponents.Button" />

    <Button
        android:id="@+id/btn_logout_pending"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Keluar"
        android:textColor="@color/primary_red"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:layout_marginTop="12dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:backgroundTint="@android:color/transparent" />

</LinearLayout>
