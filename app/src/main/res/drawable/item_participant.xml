<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_12"
    android:paddingHorizontal="@dimen/spacing_8"
    android:gravity="center_vertical">

    <!-- Avatar -->
    <ImageView
        android:id="@+id/iv_avatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_profile_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="@string/participant_avatar" />

    <!-- Participant Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_12">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_participant_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/participant_name"
                android:textSize="13sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <!-- Check Icon for Attended -->
            <ImageView
                android:id="@+id/iv_attended"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                android:tint="@color/success_color"
                android:contentDescription="@string/attended"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:marginTop="@dimen/spacing_4">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_calendar"
                android:tint="@color/text_gray"
                android:contentDescription="@string/registered_date" />

            <TextView
                android:id="@+id/tv_registered_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terdaftar 10 hari lalu"
                android:textSize="11sp"
                android:textColor="@color/text_gray"
                android:layout_marginStart="@dimen/spacing_6" />

        </LinearLayout>

    </LinearLayout>

    <!-- Status Menu -->
    <ImageButton
        android:id="@+id/btn_participant_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_more_vert"
        android:scaleType="centerInside"
        android:background="@drawable/ripple_background"
        android:tint="@color/text_gray"
        android:contentDescription="@string/more_options"
        android:layout_marginStart="@dimen/spacing_8" />

</LinearLayout>
